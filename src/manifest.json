{
  "manifest_version": 3,
  "name": "LinkedIn Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant to generate smart, context-aware comments and replies on LinkedIn.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": "assets/logo1.png"
  },
  "icons": {
    "16": "assets/logo1.png",
    "48": "assets/logo1.png",
    "128": "assets/logo1.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js",
        "content.css",
        "assets/*"
      ],
      "matches": [
        "https://*.linkedin.com/*"
      ]
    }
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.groq.com/*"
  ]
}