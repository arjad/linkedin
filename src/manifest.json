{
  "manifest_version": 3,
  "name": "LinkedIn Post Reader Sidebar",
  "version": "1.0.0",
  "description": "A sidebar for LinkedIn to read and display post content.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": "assets/logo.png"
  },
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "content.css"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.groq.com/*"
  ]
}
